---
import '@/styles/globals.css';
import { ClientRouter } from 'astro:transitions';
import ThreeHero from '@/components/ThreeHero';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Aroudra Thakur - Software Engineer & AI/ML Researcher',
  description = 'Full Stack and AI/ML Software Engineer specializing in computer vision, deep learning, and scalable web applications.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="Aroudra Thakur" />
    <meta name="theme-color" content="#0a0a0a" />
    <ClientRouter />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-canvas" aria-hidden="true">
      <ThreeHero client:load />
    </div>

    <div class="star-cursor" id="star-cursor" aria-hidden="true">
      <span class="star-cursor-burst"></span>
      <span class="star-cursor-core"></span>
      <span class="star-cursor-ring"></span>
    </div>

    <nav id="main-nav">
      <div class="nav-inner section-container">
        <a href="/#hero" class="nav-logo" aria-label="Home - Aroudra Thakur" data-nav-target="hero">
          <span class="gradient-text">Aroudra</span>
        </a>

        <ul class="nav-links" id="nav-links-desktop">
          <li><a href="/#hero" data-nav-target="hero">Home</a></li>
          <li><a href="/#about" data-nav-target="about">About</a></li>
          <li><a href="/#experience" data-nav-target="experience">Experience</a></li>
          <li><a href="/#projects" data-nav-target="projects">Projects</a></li>
          <li><a href="/#contact" data-nav-target="contact">Contact</a></li>
        </ul>

        <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Toggle menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>

      <div class="mobile-nav-overlay" id="mobile-nav-overlay">
        <ul class="mobile-nav-links">
          <li><a href="/#hero" data-nav-target="hero">Home</a></li>
          <li><a href="/#about" data-nav-target="about">About</a></li>
          <li><a href="/#experience" data-nav-target="experience">Experience</a></li>
          <li><a href="/#projects" data-nav-target="projects">Projects</a></li>
          <li><a href="/#contact" data-nav-target="contact">Contact</a></li>
        </ul>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <div class="section-container footer-inner">
        <div class="footer-brand">
          <span class="gradient-text footer-logo">Aroudra</span>
          <p>Building the future with code and AI.</p>
        </div>
        <div class="footer-links">
          <a href="/#about">About</a>
          <a href="/#projects">Projects</a>
          <a href="/#contact">Contact</a>
        </div>
        <p class="footer-copy">&copy; {new Date().getFullYear()} Aroudra Thakur. All rights reserved.</p>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const overlay = document.getElementById('mobile-nav-overlay');
      const nav = document.getElementById('main-nav');
      const navLinks = Array.from(document.querySelectorAll('[data-nav-target]')) as HTMLAnchorElement[];
      const sectionIds = ['hero', 'about', 'experience', 'projects', 'contact'];
      const cursor = document.getElementById('star-cursor');
      const supportsCustomCursor = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
      const reduceCursorMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      function closeMobileMenu() {
        btn?.setAttribute('aria-expanded', 'false');
        btn?.classList.remove('open');
        overlay?.classList.remove('open');
        document.body.style.overflow = '';
      }

      function setActiveNav() {
        const offset = window.scrollY + 140;
        let currentSection = 'hero';

        sectionIds.forEach((id) => {
          const section = document.getElementById(id);
          if (section && offset >= section.offsetTop) {
            currentSection = id;
          }
        });

        navLinks.forEach((link) => {
          link.classList.toggle('active', link.dataset.navTarget === currentSection);
        });
      }

      btn?.addEventListener('click', () => {
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!expanded));
        btn.classList.toggle('open');
        overlay?.classList.toggle('open');
        document.body.style.overflow = expanded ? '' : 'hidden';
      });

      overlay?.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', closeMobileMenu);
      });

      window.addEventListener('scroll', () => {
        const scrollY = window.scrollY;
        if (scrollY > 50) {
          nav?.classList.add('scrolled');
        } else {
          nav?.classList.remove('scrolled');
        }

        setActiveNav();
      }, { passive: true });

      window.addEventListener('load', setActiveNav);
      window.addEventListener('hashchange', setActiveNav);

      if (cursor && supportsCustomCursor) {
        document.documentElement.classList.add('custom-cursor-enabled');
        document.body.classList.add('custom-cursor-enabled');
        document.documentElement.style.setProperty('cursor', 'none', 'important');
        document.body.style.setProperty('cursor', 'none', 'important');

        let currentX = -120;
        let currentY = -120;
        let targetX = -120;
        let targetY = -120;
        let frame = 0;

        const interactiveSelector = 'a, button, [role="button"], summary, input, textarea, select, label';

        const applyCursorOverride = (element: Element | null) => {
          if (!(element instanceof HTMLElement)) return;
          element.style.setProperty('cursor', 'none', 'important');
        };

        const renderCursor = () => {
          const ease = reduceCursorMotion ? 1 : 0.24;
          currentX += (targetX - currentX) * ease;
          currentY += (targetY - currentY) * ease;

          cursor.style.setProperty('--cursor-x', `${currentX}px`);
          cursor.style.setProperty('--cursor-y', `${currentY}px`);

          if (Math.abs(targetX - currentX) > 0.1 || Math.abs(targetY - currentY) > 0.1) {
            frame = window.requestAnimationFrame(renderCursor);
          } else {
            frame = 0;
          }
        };

        const showCursor = (event: PointerEvent) => {
          if (event.pointerType && event.pointerType !== 'mouse') return;

          targetX = event.clientX;
          targetY = event.clientY;
          cursor.classList.add('visible');

          if (!frame) {
            frame = window.requestAnimationFrame(renderCursor);
          }
        };

        const updateCursorState = (event: Event) => {
          const target = event.target as Element | null;
          const interactiveTarget = target?.closest(interactiveSelector) ?? null;
          cursor.classList.toggle('interactive', Boolean(interactiveTarget));

          if (target) {
            applyCursorOverride(target);
          }

          if (interactiveTarget) {
            applyCursorOverride(interactiveTarget);
          }
        };

        const hideCursor = () => {
          cursor.classList.remove('visible', 'pressed', 'interactive');
          targetX = -120;
          targetY = -120;
          currentX = -120;
          currentY = -120;
          cursor.style.setProperty('--cursor-x', `${currentX}px`);
          cursor.style.setProperty('--cursor-y', `${currentY}px`);
        };

        window.addEventListener('pointermove', showCursor, { passive: true });
        document.addEventListener('pointerover', updateCursorState, { passive: true });
        window.addEventListener('pointerdown', () => cursor.classList.add('pressed'));
        window.addEventListener('pointerup', () => cursor.classList.remove('pressed'));
        document.addEventListener('mouseleave', hideCursor);
        window.addEventListener('blur', hideCursor);
      }
    </script>

    <script>
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!prefersReducedMotion) {
        gsap.utils.toArray('.section-reveal').forEach((el: any) => {
          gsap.to(el, {
            opacity: 1,
            y: 0,
            duration: 0.9,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: el,
              start: 'top 85%',
              toggleActions: 'play none none none',
            },
          });
        });

        gsap.utils.toArray('.stagger-grid').forEach((container: any) => {
          const cards = container.querySelectorAll('.stagger-item');
          gsap.from(cards, {
            opacity: 0,
            y: 30,
            duration: 0.6,
            stagger: 0.1,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: container,
              start: 'top 80%',
              toggleActions: 'play none none none',
            },
          });
        });
      } else {
        document.querySelectorAll('.section-reveal').forEach((el) => {
          (el as HTMLElement).style.opacity = '1';
          (el as HTMLElement).style.transform = 'none';
        });
      }
    </script>

    <style>
      #main-nav {
        position: fixed;
        top: 0;
        width: 100%;
        z-index: 1000;
        padding: 1.25rem 0;
        transition: all 0.35s cubic-bezier(0.23, 1, 0.32, 1);
        background: transparent;
      }

      .site-canvas {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
      }

      .star-cursor {
        --cursor-x: -120px;
        --cursor-y: -120px;
        --cursor-scale: 1;
        position: fixed;
        top: 0;
        left: 0;
        width: 24px;
        height: 24px;
        z-index: 5000;
        pointer-events: none;
        opacity: 0;
        transform: translate3d(var(--cursor-x), var(--cursor-y), 0) translate(-50%, -50%) scale(var(--cursor-scale));
        transition: opacity 0.2s ease, filter 0.2s ease;
        filter: drop-shadow(0 0 12px rgba(0, 255, 136, 0.28)) drop-shadow(0 0 20px rgba(0, 204, 255, 0.2));
      }

      .star-cursor.visible {
        opacity: 1;
      }

      .star-cursor.interactive {
        --cursor-scale: 1.28;
        filter: drop-shadow(0 0 16px rgba(0, 255, 136, 0.36)) drop-shadow(0 0 28px rgba(0, 204, 255, 0.24));
      }

      .star-cursor.pressed {
        --cursor-scale: 0.88;
      }

      .star-cursor.interactive.pressed {
        --cursor-scale: 1.08;
      }

      .star-cursor::before,
      .star-cursor::after {
        content: '';
        position: absolute;
        border-radius: 999px;
        pointer-events: none;
      }

      .star-cursor::before {
        inset: -12px;
        background: radial-gradient(circle, rgba(0, 255, 136, 0.18), rgba(0, 204, 255, 0.08) 48%, transparent 72%);
        filter: blur(7px);
        animation: cursorHalo 2.2s ease-in-out infinite;
      }

      .star-cursor::after {
        width: 4px;
        height: 4px;
        top: 0;
        right: 2px;
        background: #fff7c7;
        box-shadow: 0 0 10px rgba(255, 247, 199, 0.72);
        animation: cursorSparkle 1.7s ease-in-out infinite;
      }

      .star-cursor-burst,
      .star-cursor-core,
      .star-cursor-ring {
        position: absolute;
        inset: 0;
      }

      .star-cursor-burst {
        inset: -2px;
        opacity: 0;
        clip-path: polygon(
          50% 0%,
          58% 22%,
          78% 8%,
          68% 31%,
          100% 50%,
          68% 69%,
          78% 92%,
          58% 78%,
          50% 100%,
          42% 78%,
          22% 92%,
          32% 69%,
          0% 50%,
          32% 31%,
          22% 8%,
          42% 22%
        );
        background: radial-gradient(circle, rgba(255, 247, 199, 0.95), rgba(144, 255, 209, 0.7) 45%, rgba(65, 222, 255, 0.18) 100%);
        transform: scale(0.55) rotate(-8deg);
        transition: opacity 0.18s ease, transform 0.22s ease;
      }

      .star-cursor-core {
        inset: 4px;
        clip-path: polygon(50% 0%, 62% 38%, 100% 50%, 62% 62%, 50% 100%, 38% 62%, 0% 50%, 38% 38%);
        background: radial-gradient(circle at 38% 34%, #fff7c7 0%, #90ffd1 34%, #41deff 68%, rgba(65, 222, 255, 0.34) 100%);
        transform: rotate(45deg);
        transition: clip-path 0.18s ease, inset 0.18s ease, transform 0.18s ease, background 0.18s ease;
      }

      .star-cursor-ring {
        inset: 2px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: inset 0 0 0 1px rgba(0, 255, 136, 0.16);
        transition: inset 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
      }

      .star-cursor.interactive .star-cursor-burst {
        opacity: 1;
        transform: scale(1) rotate(0deg);
      }

      .star-cursor.interactive .star-cursor-core {
        inset: 6px;
        clip-path: circle(50% at 50% 50%);
        background: radial-gradient(circle at 40% 38%, #fff7c7 0%, #ffe790 40%, #90ffd1 72%, rgba(65, 222, 255, 0.3) 100%);
        transform: scale(0.94);
      }

      .star-cursor.interactive .star-cursor-ring {
        inset: 0;
        border-color: rgba(255, 247, 199, 0.3);
        box-shadow:
          inset 0 0 0 1px rgba(0, 255, 136, 0.16),
          0 0 0 1px rgba(255, 247, 199, 0.12);
      }

      @keyframes cursorHalo {
        0%, 100% { transform: scale(0.92); opacity: 0.75; }
        50% { transform: scale(1.06); opacity: 1; }
      }

      @keyframes cursorSparkle {
        0%, 100% { transform: translate3d(0, 0, 0) scale(0.9); opacity: 0.4; }
        50% { transform: translate3d(2px, -2px, 0) scale(1.35); opacity: 1; }
      }

      html.custom-cursor-enabled,
      html.custom-cursor-enabled *,
      html.custom-cursor-enabled *::before,
      html.custom-cursor-enabled *::after {
        cursor: none !important;
      }

      #main-nav.scrolled {
        background: rgba(3, 5, 7, 0.9);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid var(--border);
        padding: 0.85rem 0;
      }

      .nav-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .nav-logo {
        font-family: 'Manrope', sans-serif;
        font-size: 1.2rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .nav-links {
        display: flex;
        list-style: none;
        gap: 2.25rem;
      }

      .nav-links a,
      .mobile-nav-links a {
        color: var(--text-secondary);
        font-size: 0.9rem;
        font-weight: 500;
        transition: color 0.25s ease;
        position: relative;
      }

      .nav-links a::after {
        content: '';
        position: absolute;
        bottom: -4px;
        left: 0;
        width: 0;
        height: 2px;
        background: var(--accent);
        transition: width 0.3s ease;
      }

      .nav-links a:hover,
      .nav-links a.active,
      .mobile-nav-links a:hover,
      .mobile-nav-links a.active {
        color: var(--accent);
      }

      .nav-links a:hover::after,
      .nav-links a.active::after {
        width: 100%;
      }

      .mobile-menu-btn {
        display: none;
        flex-direction: column;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 4px;
        z-index: 1001;
      }

      .mobile-menu-btn span {
        display: block;
        width: 24px;
        height: 2px;
        background: var(--text-primary);
        transition: all 0.3s ease;
        border-radius: 1px;
      }

      .mobile-menu-btn.open span:nth-child(1) {
        transform: rotate(45deg) translate(5px, 5px);
      }

      .mobile-menu-btn.open span:nth-child(2) {
        opacity: 0;
      }

      .mobile-menu-btn.open span:nth-child(3) {
        transform: rotate(-45deg) translate(5px, -5px);
      }

      .mobile-nav-overlay {
        position: fixed;
        inset: 0;
        background: rgba(10, 10, 10, 0.98);
        backdrop-filter: blur(20px);
        z-index: 999;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.35s ease;
      }

      .mobile-nav-overlay.open {
        opacity: 1;
        pointer-events: all;
      }

      .mobile-nav-links {
        list-style: none;
        text-align: center;
        display: flex;
        flex-direction: column;
        gap: 2rem;
      }

      .mobile-nav-links a {
        font-family: 'Manrope', sans-serif;
        font-size: 1.8rem;
        font-weight: 600;
      }

      @media (max-width: 768px) {
        .nav-links {
          display: none;
        }

        .mobile-menu-btn {
          display: flex;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .star-cursor::before,
        .star-cursor::after {
          animation: none;
        }
      }

      footer {
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        padding: 3rem 0;
        margin-top: 2rem;
        position: relative;
        background: linear-gradient(180deg, rgba(7, 10, 18, 0), rgba(7, 10, 18, 0.72));
      }

      .footer-inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.25rem;
        text-align: center;
      }

      .footer-logo {
        font-family: 'Manrope', sans-serif;
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .footer-brand p {
        color: var(--text-secondary);
        font-size: 0.9rem;
        margin-top: 0.25rem;
      }

      .footer-links {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
        justify-content: center;
      }

      .footer-links a {
        color: var(--text-secondary);
        font-size: 0.9rem;
        font-weight: 500;
        transition: color 0.25s ease;
      }

      .footer-links a:hover {
        color: var(--accent);
      }

      .footer-copy {
        color: var(--text-secondary);
        font-size: 0.8rem;
        opacity: 0.6;
      }
    </style>
  </body>
</html>
