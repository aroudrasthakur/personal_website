---
import Layout from '@/layouts/Layout.astro';
import SkillTags from '@/components/SkillTags';

const skillCategories = [
  { name: 'Languages', skills: ['Python', 'JavaScript', 'TypeScript', 'Java', 'C', 'PHP', 'HTML/CSS'] },
  { name: 'Frontend', skills: ['React', 'React Native', 'Next.js', 'Vue.js', 'Expo', 'jQuery'] },
  { name: 'Backend & Databases', skills: ['Node.js', 'Django', 'Flask', 'PostgreSQL', 'MySQL', 'REST APIs', 'GraphQL'] },
  { name: 'AI/ML & Computer Vision', skills: ['TensorFlow', 'PyTorch', 'Keras', 'OpenCV', 'Mediapipe', 'CNNs', 'GCNs', 'Transformers', 'NLP', 'DTW'] },
  { name: 'Cloud & DevOps', skills: ['AWS', 'Docker', 'Git', 'GitHub Actions', 'Apache'] },
  { name: 'Other', skills: ['Raspberry Pi', 'Embedded Systems', 'IoT', 'Event-Based Vision', 'Agile', 'WordPress'] },
];

const highlights = [
  'Developed scalable SaaS modules at TopSource Worldwide and Hotspring, optimizing APIs and UI performance',
  'Published research in IEEE Access on human pose estimation using deep learning',
  'Built LangPal, a full-featured language learning platform with real-time chat and partner matching',
  'Created AI-powered applications for fitness form correction, slang detection, and autonomous driving',
  'Leading development of MavsPrep as ACM Create Member, providing academic resources to UTA students',
];

const workAreas = [
  'Full-stack web applications with modern frameworks and responsive design',
  'AI/ML systems for computer vision, pose estimation, and natural language processing',
  'Research in human pose estimation, ASL recognition, and event-based vision',
  'Mobile applications with React Native and cross-platform development',
  'Cloud infrastructure, automation, and performance optimization',
];
---

<Layout title="About — Aroudra Thakur" description="Learn about Aroudra Thakur's skills, experience, and technical background in software engineering and AI/ML.">
  <section class="section-reveal page-header-section">
    <div class="section-container">
      <div class="section-header">
        <h1>About Me</h1>
      </div>
      <div class="about-intro">
        <p>
          I'm Aroudra Thakur — a Computer Science student at The University of Texas at Arlington with a passion for
          Full Stack Development and AI/ML. I specialize in building scalable web applications, developing intelligent
          systems using computer vision and deep learning, and creating user-centered products that solve real-world problems.
        </p>
      </div>
    </div>
  </section>

  <section class="section-reveal skills-section">
    <div class="section-container">
      <h2 class="sub-heading gradient-text">Technical Skills</h2>
      <div class="skills-grid">
        {skillCategories.map(cat => (
          <div class="skill-category glass-card">
            <h3>{cat.name}</h3>
            <SkillTags skills={cat.skills} client:visible />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-reveal what-section">
    <div class="section-container">
      <h2 class="sub-heading gradient-text">What I Work On</h2>
      <ul class="work-list">
        {workAreas.map(area => (
          <li class="glass-card work-item">
            <span class="work-bullet">→</span>
            <span>{area}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section-reveal highlights-section">
    <div class="section-container">
      <h2 class="sub-heading gradient-text">Highlights</h2>
      <ul class="highlights-list">
        {highlights.map(h => (
          <li class="glass-card highlight-item">
            <span class="highlight-check">✦</span>
            <span>{h}</span>
          </li>
        ))}
      </ul>

      <div class="back-link">
        <a href="/" class="outline-button">← Back to Home</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header-section {
    padding: 10rem 0 3rem;
  }

  .about-intro {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .about-intro p {
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.8;
  }

  .sub-heading {
    font-size: 1.75rem;
    margin-bottom: 2rem;
  }

  .skills-section,
  .what-section,
  .highlights-section {
    padding: 3rem 0;
  }

  .skills-section { background: var(--bg-secondary); padding: 4rem 0; }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .skill-category {
    padding: 1.5rem;
  }

  .skill-category h3 {
    font-size: 0.95rem;
    color: var(--text-primary);
    margin-bottom: 0.85rem;
    font-weight: 600;
  }

  .work-list,
  .highlights-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 800px;
  }

  .work-item,
  .highlight-item {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
  }

  .work-bullet {
    color: var(--accent);
    font-weight: 700;
    flex-shrink: 0;
  }

  .highlight-check {
    color: var(--accent);
    flex-shrink: 0;
  }

  .work-item span:last-child,
  .highlight-item span:last-child {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .back-link {
    margin-top: 3rem;
  }

  @media (max-width: 768px) {
    .page-header-section { padding: 8rem 0 2rem; }
    .skills-grid { grid-template-columns: 1fr; }
  }
</style>
