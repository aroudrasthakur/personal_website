---
import Layout from '@/layouts/Layout.astro';
import SkillTicker from '@/components/SkillTicker.astro';
import ExperienceCarousel from '@/components/ExperienceCarousel';
import ProjectShowcase from '@/components/ProjectShowcase';
import EmailPopup from '@/components/EmailPopup';
import profileImage from '../../profile.jpg';
import {
  experiences,
  projects,
  newsUpdates,
  newsLastUpdated,
  formatNewsDate,
  sortExperiencesByNewest,
  sortNewsByNewest,
  sortProjectsByPriority,
} from '@/lib/data';

const sortedExperiences = sortExperiencesByNewest(experiences);
const sortedProjects = sortProjectsByPriority(projects);
const sortedNews = sortNewsByNewest(newsUpdates);
const leadNews = sortedNews[0];
const restNews = sortedNews.slice(1);
const mastheadDate = formatNewsDate(newsLastUpdated);

const spotlightStats = [
  { value: '10+', label: 'roles and research tracks' },
  { value: '15+', label: 'projects shipped' },
  { value: '3', label: 'research publications' },
];

const workAreas = [
  'Full-stack systems that feel polished in the UI and reliable under the hood.',
  'AI and computer vision work spanning pose estimation, ASL recognition, and event-based vision.',
  'Research-backed engineering that turns prototypes into practical, user-facing products.',
];

const tickerItems = [
  { label: 'PYTHON', signal: 'CORE' },
  { label: 'REACT', signal: 'SHIPPED' },
  { label: 'DJANGO', signal: 'BACKEND' },
  { label: 'PYTORCH', signal: 'RESEARCH' },
  { label: 'AWS', signal: 'DEPLOYED' },
  { label: 'TYPESCRIPT', signal: 'FULLSTACK' },
  { label: 'COMPUTER-VISION', signal: 'ACTIVE' },
  { label: 'DOCKER', signal: 'DELIVERED' },
  { label: 'FASTAPI', signal: 'BUILDING' },
  { label: 'NEXTJS', signal: 'PRODUCT' },
];
---

<Layout>
  <section id="hero" class="hero-section page-anchor-section" data-nav-section>
    <div class="hero-overlay">
      <div class="section-container hero-content">
        <p class="hero-greeting">Hello, I'm</p>
        <h1 class="hero-name gradient-text">Aroudra Thakur</h1>
        <p class="hero-subtitle">Full Stack & AI/ML Software Engineer</p>
        <p class="hero-sub2">Computer Vision Enthusiast | Researcher | Builder</p>
        <div class="hero-actions">
          <a href="#about" class="glow-button">Explore My Work</a>
          <a href="#projects" class="outline-button">Jump to Projects</a>
        </div>
      </div>
    </div>
    <div class="hero-scroll-indicator" aria-hidden="true">
      <div class="scroll-line"></div>
    </div>
  </section>

  <section id="about" class="section-reveal about-section page-anchor-section" data-nav-section>
    <div class="section-container">
      <div class="about-hero glass-card">
        <div class="about-portrait-panel">
          <div class="portrait-frame">
            <img src={profileImage.src} alt="Portrait of Aroudra Thakur" class="portrait-image" />
          </div>
          <div class="portrait-caption">
            <span class="portrait-kicker">UTA Honors Computer Science</span>
            <p>
              Building full-stack products and AI systems with a focus on accessibility, vision, and clean user experiences.
            </p>
          </div>

          {leadNews && (
            <aside class="newspaper" aria-label="Latest updates">
              <div class="newsflash-sign" role="status" aria-live="polite">
                <span class="newsflash-star newsflash-star-left" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="14" height="14">
                    <path
                      d="M12 1.5l2.18 6.7H21l-5.41 4.14L17.77 19 12 14.96 6.23 19l2.18-6.66L3 8.2h6.82L12 1.5z"
                      fill="currentColor"
                    />
                  </svg>
                </span>
                <span class="newsflash-text">NewsFlash</span>
                <span class="newsflash-star newsflash-star-right" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="14" height="14">
                    <path
                      d="M12 1.5l2.18 6.7H21l-5.41 4.14L17.77 19 12 14.96 6.23 19l2.18-6.66L3 8.2h6.82L12 1.5z"
                      fill="currentColor"
                    />
                  </svg>
                </span>
                <span class="newsflash-sparkle newsflash-sparkle-1" aria-hidden="true"></span>
                <span class="newsflash-sparkle newsflash-sparkle-2" aria-hidden="true"></span>
                <span class="newsflash-sparkle newsflash-sparkle-3" aria-hidden="true"></span>
                <span class="newsflash-sparkle newsflash-sparkle-4" aria-hidden="true"></span>
              </div>
              <header class="newspaper-masthead">
                <time class="newspaper-issue-date" datetime={newsLastUpdated}>{mastheadDate}</time>
                <h3 class="newspaper-title">The <span class="newspaper-title-name">Aroudra</span> Times</h3>
              </header>
              <div class="newspaper-rule" aria-hidden="true"></div>

              <article class="newspaper-lead">
                <div class="newspaper-date-row">
                  <time class="newspaper-date-tab" datetime={leadNews.date}>
                    {formatNewsDate(leadNews.date)}
                  </time>
                  {leadNews.kicker && (
                    <span class="newspaper-kicker">{leadNews.kicker}</span>
                  )}
                </div>
                <h4 class="newspaper-headline">{leadNews.headline}</h4>
                {leadNews.body && (
                  <p class="newspaper-body">{leadNews.body}</p>
                )}
              </article>

              {restNews.length > 0 && (
                <>
                  <div class="newspaper-rule newspaper-rule-thin" aria-hidden="true"></div>
                  <ul class="newspaper-archive">
                    {restNews.map((item) => (
                      <li class="newspaper-archive-item">
                        <time class="newspaper-date-tab newspaper-date-tab-sm" datetime={item.date}>
                          {formatNewsDate(item.date)}
                        </time>
                        <div class="newspaper-archive-body">
                          {item.kicker && (
                            <span class="newspaper-kicker newspaper-kicker-sm">{item.kicker}</span>
                          )}
                          <span class="newspaper-archive-headline">{item.headline}</span>
                          {item.body && (
                            <p class="newspaper-archive-text">{item.body}</p>
                          )}
                        </div>
                      </li>
                    ))}
                  </ul>
                </>
              )}
            </aside>
          )}
        </div>

        <div class="about-copy-panel">
          <p class="page-kicker">About Me</p>
          <h2>Engineer, researcher, and builder focused on turning ambitious ideas into working systems.</h2>
          <p class="about-lead">
            I'm Aroudra Thakur, CS student at UT Arlington building at the intersection of AI/ML and full-stack engineering. I've architected production AI systems, shipped full-stack features on live platforms, and published research in computer vision spanning human pose estimation, ASL recognition, and event-based vision.
          </p>
          <p class="about-body">
            My stack spans PyTorch, LLM orchestration, RAG, React, Django, PostgreSQL, GraphQL, and AWS. I care about systems that are rigorous under the hood and intuitive on the surface, whether that means a well-tuned retrieval pipeline or a dashboard someone actually wants to use. I don't just prototype. I own things end-to-end, from model to interface to deployment.
          </p>

          <div class="about-pill-row">
            <span class="about-pill">Software Engineering</span>
            <span class="about-pill">AI Engineering</span>
            <span class="about-pill">Agentic Development</span>
            <span class="about-pill">Computer Vision</span>
          </div>

          <div class="spotlight-stats">
            {spotlightStats.map((stat) => (
              <div class="spotlight-stat">
                <strong class="gradient-text">{stat.value}</strong>
                <span>{stat.label}</span>
              </div>
            ))}
          </div>

          <div class="work-areas">
            {workAreas.map((area, i) => (
              <div class="work-area" style={`--work-area-index:${i};`}>
                <span class="work-area-mark" aria-hidden="true">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <div class="work-area-body">
                  <p>{area}</p>
                </div>
                <span class="work-area-arrow" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="13 6 19 12 13 18" />
                  </svg>
                </span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-reveal ticker-section" aria-label="Skills ticker section">
    <SkillTicker items={tickerItems} />
  </section>

  <section id="experience" class="section-reveal experience-section page-anchor-section" data-nav-section>
    <div class="section-container">
      <div class="section-header section-header-left">
        <h2>Experience</h2>
      </div>
      <ExperienceCarousel items={sortedExperiences} client:visible />
    </div>
  </section>

  <section id="projects" class="section-reveal projects-section page-anchor-section" data-nav-section>
    <div class="section-container">
      <div class="section-header section-header-left">
        <h2>Projects</h2>
      </div>
      <ProjectShowcase items={sortedProjects} client:visible />
    </div>
  </section>

  <section id="contact" class="section-reveal contact-section page-anchor-section" data-nav-section>
    <div class="section-container">
      <div class="section-header">
        <h2>Get In Touch</h2>
        <p>I'm always open to discussing new projects, creative ideas, or opportunities.</p>
      </div>

      <div class="contact-cards">
        <EmailPopup client:load />
        <a
          href="tel:+16824067019"
          class="contact-card-link"
        >
          <span class="contact-card-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="img">
              <path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1-.24c1.1.37 2.28.56 3.49.56a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.21.19 2.39.56 3.49a1 1 0 0 1-.25 1.01l-2.19 2.29Z" />
            </svg>
          </span>
          <span>Call</span>
        </a>
        <a
          href="https://github.com/aroudrasthakur"
          class="contact-card-link"
          target="_blank"
          rel="noreferrer"
        >
          <span class="contact-card-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="img">
              <path d="M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.42-4.04-1.42-.55-1.38-1.33-1.75-1.33-1.75-1.09-.74.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.08 1.82 2.82 1.3 3.5.99.11-.77.42-1.3.76-1.59-2.67-.31-5.47-1.34-5.47-5.95 0-1.31.47-2.38 1.24-3.22-.12-.31-.54-1.57.12-3.27 0 0 1.01-.32 3.3 1.23a11.43 11.43 0 0 1 6 0c2.28-1.55 3.29-1.23 3.29-1.23.67 1.7.25 2.96.12 3.27.77.84 1.23 1.91 1.23 3.22 0 4.62-2.81 5.63-5.49 5.93.43.37.81 1.1.81 2.22v3.29c0 .32.21.7.83.58A12 12 0 0 0 12 .5Z" />
            </svg>
          </span>
          <span>GitHub</span>
        </a>
        <a
          href="https://www.linkedin.com/in/aroudra-thakur-69203630a/"
          class="contact-card-link"
          target="_blank"
          rel="noreferrer"
        >
          <span class="contact-card-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="img">
              <path d="M6.94 8.5H3.56V20h3.38V8.5ZM5.25 3A1.97 1.97 0 1 0 5.3 6.94 1.97 1.97 0 0 0 5.25 3Zm14.19 9.85c0-3.46-1.85-5.07-4.32-5.07-1.99 0-2.88 1.09-3.38 1.86V8.5H8.37c.05.76 0 11.5 0 11.5h3.37v-6.42c0-.34.02-.68.13-.92.27-.67.88-1.37 1.91-1.37 1.34 0 1.88 1.03 1.88 2.55V20H19V13.4c0-.18 0-.37-.01-.55Z" />
            </svg>
          </span>
          <span>LinkedIn</span>
        </a>
      </div>
    </div>
  </section>

  <script>
    import gsap from 'gsap';

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!prefersReduced) {
      const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
      tl.from('.hero-greeting', { opacity: 0, y: 30, duration: 0.7, delay: 0.3 })
        .from('.hero-name', { opacity: 0, y: 40, duration: 0.8 }, '-=0.3')
        .from('.hero-subtitle', { opacity: 0, y: 25, duration: 0.6 }, '-=0.3')
        .from('.hero-sub2', { opacity: 0, y: 20, duration: 0.5 }, '-=0.2')
        .from('.hero-actions', { opacity: 0, y: 20, duration: 0.5 }, '-=0.2')
        .from('.hero-scroll-indicator', { opacity: 0, duration: 0.8 }, '-=0.2');
    }
  </script>
</Layout>

<style>
  .page-anchor-section {
    scroll-margin-top: 96px;
  }

  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    opacity: 1 !important;
    transform: none !important;
  }

  .hero-overlay {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 2rem;
  }

  .hero-greeting {
    font-size: 1.1rem;
    color: var(--accent);
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .hero-name {
    font-size: clamp(2.8rem, 7vw, 5rem);
    font-weight: 700;
    letter-spacing: -0.06em;
    margin-bottom: 1rem;
    line-height: 0.98;
  }

  .hero-subtitle {
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
    font-weight: 400;
  }

  .hero-sub2 {
    font-size: 1rem;
    color: var(--text-secondary);
    opacity: 0.7;
    margin-bottom: 2.5rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
  }

  .scroll-line {
    width: 1px;
    height: 50px;
    background: linear-gradient(180deg, var(--accent), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.7); }
    50% { opacity: 1; transform: scaleY(1); }
  }

  .about-section {
    padding: 4rem 0 3rem;
    background:
      radial-gradient(circle at 22% 18%, rgba(0, 255, 136, 0.08), transparent 20%),
      radial-gradient(circle at 82% 26%, rgba(0, 204, 255, 0.08), transparent 18%),
      linear-gradient(180deg, rgba(4, 7, 13, 0), rgba(7, 16, 27, 0.64) 18%, rgba(4, 7, 13, 0.86));
  }

  .about-hero {
    display: grid;
    grid-template-columns: 0.82fr 1.18fr;
    gap: 2rem;
    padding: 2rem;
    background:
      radial-gradient(circle at top left, rgba(0, 255, 136, 0.08), transparent 24%),
      radial-gradient(circle at bottom right, rgba(0, 204, 255, 0.08), transparent 24%),
      linear-gradient(140deg, rgba(14, 21, 33, 0.96), rgba(8, 12, 20, 0.82));
  }

  .about-portrait-panel {
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .portrait-frame {
    position: relative;
    overflow: hidden;
    border-radius: calc(var(--radius-lg) + 6px);
    min-height: 440px;
    background:
      radial-gradient(circle at 24% 18%, rgba(0, 255, 136, 0.12), transparent 26%),
      linear-gradient(135deg, rgba(13, 24, 36, 0.94), rgba(8, 12, 20, 0.84));
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .portrait-frame::after {
    content: '';
    position: absolute;
    inset: auto 0 0 0;
    height: 45%;
    background: linear-gradient(180deg, transparent, rgba(10, 10, 10, 0.45));
    pointer-events: none;
  }

  .portrait-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .portrait-caption {
    padding: 1.2rem 1.35rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.02);
  }

  .newsflash-sign {
    position: relative;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    align-self: center;
    margin: 0 auto 0.85rem;
    padding: 0.4rem 1rem;
    border-radius: 999px;
    border: 1.5px solid rgba(255, 234, 120, 0.7);
    background:
      radial-gradient(circle at 20% 30%, rgba(255, 220, 100, 0.22), transparent 60%),
      linear-gradient(135deg, rgba(28, 18, 8, 0.92), rgba(14, 10, 4, 0.92));
    color: #ffe277;
    font-family: 'Manrope', sans-serif;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    box-shadow:
      0 0 0 1px rgba(255, 234, 120, 0.28),
      0 0 22px rgba(255, 210, 80, 0.5),
      inset 0 0 14px rgba(255, 230, 130, 0.28);
    overflow: visible;
    text-shadow: 0 0 6px rgba(255, 220, 100, 0.6);
    will-change: opacity;
    animation: newsflashFlash 1.8s ease-in-out infinite;
    contain: layout paint;
  }

  .newspaper > .newsflash-sign {
    display: flex;
    width: max-content;
    max-width: 100%;
  }

  .newsflash-text {
    position: relative;
    z-index: 1;
  }

  .newsflash-star {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #fff3a8;
    animation: newsflashSpin 5s linear infinite;
    will-change: transform;
  }

  .newsflash-star-right {
    animation-direction: reverse;
    animation-duration: 6s;
  }

  .newsflash-sparkle {
    position: absolute;
    width: 4px;
    height: 4px;
    border-radius: 999px;
    background: #fff8d0;
    opacity: 0;
    animation: newsflashSparkle 2.2s ease-in-out infinite;
    will-change: opacity;
  }

  .newsflash-sparkle-1 { top: -3px; left: 18%; animation-delay: 0s; }
  .newsflash-sparkle-2 { bottom: -3px; right: 18%; animation-delay: 1.1s; }
  .newsflash-sparkle-3,
  .newsflash-sparkle-4 { display: none; }

  @keyframes newsflashFlash {
    0%, 100% { opacity: 0.85; }
    50% { opacity: 1; }
  }

  @keyframes newsflashSpin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @keyframes newsflashSparkle {
    0%, 100% { opacity: 0; }
    50% { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .newsflash-sign,
    .newsflash-star,
    .newsflash-sparkle {
      animation: none;
    }

    .newsflash-sparkle {
      opacity: 1;
    }
  }

  .newspaper {
    --newspaper-paper: #f1ead7;
    --newspaper-paper-edge: #d8cfb4;
    --newspaper-ink: #14110c;
    --newspaper-ink-soft: #3d362a;
    --newspaper-ink-muted: #6b6353;
    --newspaper-rule: #14110c;
    --newspaper-accent: #8a1010;

    position: relative;
    display: flex;
    flex-direction: column;
    padding: 1.4rem 1.45rem 1.5rem;
    border-radius: 4px;
    border: 1px solid var(--newspaper-paper-edge);
    background:
      radial-gradient(circle at 20% 12%, rgba(120, 88, 40, 0.07), transparent 55%),
      radial-gradient(circle at 82% 86%, rgba(80, 50, 20, 0.08), transparent 60%),
      repeating-linear-gradient(
        0deg,
        rgba(0, 0, 0, 0.018) 0,
        rgba(0, 0, 0, 0.018) 1px,
        transparent 1px,
        transparent 3px
      ),
      linear-gradient(180deg, #f4eddc 0%, #ece4cf 100%);
    color: var(--newspaper-ink);
    font-family: 'Georgia', 'Times New Roman', serif;
    overflow: hidden;
    container-type: inline-size;
    contain: layout style paint;
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.4),
      0 1px 0 rgba(0, 0, 0, 0.25),
      0 10px 24px rgba(0, 0, 0, 0.35);
  }

  .newspaper::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      radial-gradient(rgba(20, 17, 12, 0.22) 1px, transparent 1.4px);
    background-size: 4px 4px;
    opacity: 0.16;
  }

  .newspaper::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse at top, rgba(20, 17, 12, 0.06), transparent 60%),
      radial-gradient(ellipse at bottom right, rgba(60, 35, 10, 0.08), transparent 60%);
  }

  .newspaper-masthead {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.25rem;
    text-align: center;
    position: relative;
    z-index: 1;
    min-width: 0;
  }

  .newspaper-issue-date {
    display: block;
    font-family: 'Georgia', 'Times New Roman', serif;
    font-size: 0.64rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--newspaper-ink-soft);
    text-align: right;
    font-style: italic;
    white-space: nowrap;
  }

  .newspaper-title {
    display: block;
    font-family: 'Chomsky', 'Times New Roman', Times, serif;
    font-size: clamp(1.35rem, 11cqi, 2.6rem);
    font-weight: 400;
    letter-spacing: 0.02em;
    line-height: 1.05;
    margin: 0;
    color: var(--newspaper-ink);
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.45);
    white-space: nowrap;
    text-align: center;
  }

  .newspaper-title-name {
    display: inline;
    margin: 0 0.06em;
    color: var(--newspaper-ink);
    background: transparent;
    border: none;
    padding: 0;
    box-shadow: none;
    text-shadow: none;
    font-family: inherit;
    letter-spacing: 0.02em;
  }

  .newspaper-rule {
    position: relative;
    z-index: 1;
    height: 5px;
    margin: 0.75rem 0 0.95rem;
    border-top: 2.5px solid var(--newspaper-rule);
    border-bottom: 1px solid var(--newspaper-rule);
  }

  .newspaper-rule-thin {
    height: 0;
    margin: 1rem 0;
    border-top: 1px solid rgba(20, 17, 12, 0.32);
    border-bottom: none;
  }

  .newspaper-lead,
